    <!-- http://w3id.org/opino/AssertionValue -->


    <owl:NamedIndividual rdf:about="http://w3id.org/opino/AssertionValue">
        <rdf:type rdf:resource="http://w3id.org/opino/EpistemicRegion"/>
        <rdfs:comment xml:lang="en">An opinion the holder commits to as their current considered interpretation, supported by evidence or argument they regard as sufficient.</rdfs:comment>
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">http://w3id.org/opino/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Assertion (Region)</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://w3id.org/opino/ConjectureValue -->


    <owl:NamedIndividual rdf:about="http://w3id.org/opino/ConjectureValue">
        <rdf:type rdf:resource="http://w3id.org/opino/EpistemicRegion"/>
        <rdfs:comment xml:lang="en">An opinion entertained as a possibility without sufficient evidence to assert it. The holder acknowledges the claim is speculative.</rdfs:comment>
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">http://w3id.org/opino/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Conjecture (Region)</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://w3id.org/opino/HypothesisValue -->


    <owl:NamedIndividual rdf:about="http://w3id.org/opino/HypothesisValue">
        <rdf:type rdf:resource="http://w3id.org/opino/EpistemicRegion"/>
        <rdfs:comment xml:lang="en">An opinion held tentatively, pending further evidence or argument. The holder commits to it as the current best explanation while remaining open to revision.</rdfs:comment>
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">http://w3id.org/opino/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Hypothesis (Region)</rdfs:label>
    </owl:NamedIndividual>
    <rdf:Description>
        <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
    </rdf:Description>
    


