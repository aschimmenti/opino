    <!-- http://purl.org/emmedi/hico/InterpretationAct -->


    <owl:Class rdf:about="http://purl.org/emmedi/hico/InterpretationAct"/>
    


    <!-- http://w3id.org/opino/Assertion -->


    <owl:Class rdf:about="http://w3id.org/opino/Assertion">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://w3id.org/opino/Opinion"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://w3id.org/opino/hasEpistemicStatus"/>
                        <owl:hasValue rdf:resource="http://w3id.org/opino/AssertionValue"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:comment xml:lang="en">An Opinion the holder commits to as their current considered interpretation, supported by evidence or argument they regard as sufficient to warrant commitment.</rdfs:comment>
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">http://w3id.org/opino/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Assertion</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/opino/Conjecture -->


    <owl:Class rdf:about="http://w3id.org/opino/Conjecture">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://w3id.org/opino/Opinion"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://w3id.org/opino/hasEpistemicStatus"/>
                        <owl:hasValue rdf:resource="http://w3id.org/opino/ConjectureValue"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:comment xml:lang="en">An Opinion held with minimal epistemic commitment, entertained as a possibility without sufficient evidence to assert it.</rdfs:comment>
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">http://w3id.org/opino/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Conjecture</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/opino/Construal -->


    <owl:Class rdf:about="http://w3id.org/opino/Construal">
        <rdfs:subClassOf rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Situation"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://w3id.org/opino/hasPart"/>
                <owl:allValuesFrom rdf:resource="http://w3id.org/opino/Construal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A situation constituted by the premises as perceived by the agent responsible for an Opinion. It is perspective-dependent — it reifies the state of affairs from the standpoint of the cognizer, not an objective state of affairs. A Construal can be composed of parts, each of which is itself a dul:Situation representing an individual premise (i.e., another state of affairs). The dul:Situation, part of the Construal, can be satisfied by a secondary dul:Description.</rdfs:comment>
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">http://w3id.org/opino/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Construal</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/opino/EpistemicRegion -->


    <owl:Class rdf:about="http://w3id.org/opino/EpistemicRegion">
        <rdfs:subClassOf rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Region"/>
        <rdfs:comment xml:lang="en">A region in the epistemic quality space representing the degree of individual commitment an agent holds toward an Opinion. Three values are defined: ConjectureValue (speculative), HypothesisValue (tentative), AssertionValue (committed). Community-level reception is handled separately via CiTO properties on hico:InterpretationAct.</rdfs:comment>
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">http://w3id.org/opino/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Epistemic Region</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/opino/EpistemicStatusParameter -->


    <owl:Class rdf:about="http://w3id.org/opino/EpistemicStatusParameter">
        <rdfs:subClassOf rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Parameter"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://w3id.org/opino/hasEpistemicRegion"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://w3id.org/opino/EpistemicRegion"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A parameter component of an Opinion that carries its epistemic status value. In DnS terms, this is a typed component of the Description that gets valued by a region in the epistemic quality space. Each Opinion has exactly one EpistemicStatusParameter at any given time.</rdfs:comment>
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">http://w3id.org/opino/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Epistemic Status (Parameter)</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/opino/Hypothesis -->


    <owl:Class rdf:about="http://w3id.org/opino/Hypothesis">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://w3id.org/opino/Opinion"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://w3id.org/opino/hasEpistemicStatus"/>
                        <owl:hasValue rdf:resource="http://w3id.org/opino/HypothesisValue"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:comment xml:lang="en">An Opinion held tentatively as the current best explanation, pending further evidence or argument. The holder commits to it provisionally while remaining open to revision.</rdfs:comment>
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">http://w3id.org/opino/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Hypothesis</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/opino/Interpretation -->


    <owl:Class rdf:about="http://w3id.org/opino/Interpretation">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://w3id.org/opino/Opinion"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.w3.org/ns/prov#wasGeneratedBy"/>
                        <owl:someValuesFrom rdf:resource="http://purl.org/emmedi/hico/InterpretationAct"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:comment xml:lang="en">An Opinion that results specifically from a hermeneutical interpretive act as defined by HiCO (hico:InterpretationAct). Distinguished from a generic Opinion by the type of prov:Activity that generated it. An Interpretation may simultaneously be a Conjecture, Hypothesis, or Assertion depending on its epistemic status.</rdfs:comment>
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">http://w3id.org/opino/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Interpretation</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/opino/Opinion -->


    <owl:Class rdf:about="http://w3id.org/opino/Opinion">
        <rdfs:subClassOf rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Description"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/ns/prov#wasGeneratedBy"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/ns/prov#Activity"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A description, in the DnS sense, representing a claim held by an agent about an entity or state of affairs. An Opinion is satisfied by a Construal — the set of facts as perceived by the cognizer that grounds the claim. An Opinion is generated by a prov:Activity, which attributes it to the agent responsible for its production.</rdfs:comment>
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">http://w3id.org/opino/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Opinion</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/opino/TimeIndexedConstrual -->


    <owl:Class rdf:about="http://w3id.org/opino/TimeIndexedConstrual">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://w3id.org/opino/Construal"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://w3id.org/opino/holdsAtTime"/>
                        <owl:someValuesFrom rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#TimeInterval"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:comment xml:lang="en">A Construal where the perceived state of affairs holds only during a specific time interval. Inherits from both opino:Construal — carrying the perspectival and epistemic properties of a perception — and dul:TimeIndexedRelation, which provides the temporal bounding mechanism. Used when the perceived premises are not timeless observations but temporally bounded states of affairs, such as attributions, classifications, or roles that held only during a specific period.</rdfs:comment>
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">http://w3id.org/opino/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Time-Indexed Construal</rdfs:label>
    </owl:Class>
    


    <!-- http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Collective -->


    <owl:Class rdf:about="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Collective"/>
    


